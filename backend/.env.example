# ============================================
# CASHEW FORECAST BACKEND - ENVIRONMENT CONFIG
# ============================================

# Application
APP_NAME="Cashew Forecast System"
APP_VERSION="0.2.0-node"
APP_MODE="development"  # or "production"
BACKEND_PORT=8000

# Data & Storage
DATA_DIR="../data"
DEMO_PRICE_DATA_FILE="raw_2025.xlsx"
CACHE_DIR="outputs/cache"
LOG_DIR="logs"

# LLM Provider (optional)
LLM_PROVIDER="none"  # Options: none, openai, claude
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
LLM_MAX_CALLS_PER_MIN=5
LLM_MAX_CALLS_PER_DAY=50

# ============================================
# DATABASE CONFIGURATION (MySQL)
# ============================================
# Set DB_TYPE to 'mysql' to enable database features
# Leave as 'none' to use file-based storage only

DB_TYPE="mysql"           # Options: mysql, postgresql, sqlite, mongodb, none
DB_HOST="localhost"       # MySQL server host
DB_PORT=3306              # MySQL server port
DB_NAME="cashew_db"       # Database name
DB_USER="root"            # MySQL username
DB_PASSWORD="your_password_here"  # MySQL password
DB_SSL="false"            # Use SSL connection (true/false)

# ============================================
# AUTHENTICATION (Cookie-based sessions)
# ============================================
SESSION_MAX_AGE=1800      # Session timeout in seconds (30 minutes)
COOKIE_SECRET="cashew-forecast-secret-change-in-production"

# ============================================
# NOTES:
# ============================================
# 1. Copy this file to .env and fill in your values
# 2. Never commit .env file to git (already in .gitignore)
# 3. For Parity Tool to work, you need:
#    - DB_TYPE="mysql"
#    - Valid MySQL credentials
#    - Stored procedure: PTool_run_parity_v1_0
#    - Tables: PTool_rcn_parity_calculations, PTool_origin_lookup_data
