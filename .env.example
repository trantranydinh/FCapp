# ============================================
# CASHEW FORECAST SYSTEM - ENVIRONMENT CONFIG
# ============================================
# Copy this file to .env and fill in your values

# ========== BACKEND CONFIGURATION ==========
BACKEND_PORT=8000
APP_NAME=Cashew Forecast System
APP_VERSION=0.2.0
APP_MODE=development
# APP_MODE=production

# ========== DATA DIRECTORIES ==========
DATA_DIR=./data
CACHE_DIR=./outputs/cache
LOG_DIR=./logs
DEMO_PRICE_DATA_FILE=raw_2025.xlsx

# ========== AZURE FABRIC LAKEHOUSE CONFIGURATION ==========
# REQUIRED for Fabric Lakehouse integration
# Get these values from your Azure Fabric workspace

# SQL Analytics Endpoint (format: xxxxx.datawarehouse.fabric.microsoft.com)
LAKEHOUSE_SERVER=

# Database name in Lakehouse
LAKEHOUSE_DATABASE=

# Table name (default: dbo.market_prices)
LAKEHOUSE_TABLE=dbo.market_prices

# Workspace and Lakehouse IDs (for REST API if needed)
LAKEHOUSE_WORKSPACE_ID=
LAKEHOUSE_ID=

# Authentication Type: 'device_code' or 'sql_login'
# - device_code: Interactive browser login (recommended)
# - sql_login: Username/password (if supported by your Fabric setup)
LAKEHOUSE_AUTH_TYPE=device_code

# SQL Login credentials (only if LAKEHOUSE_AUTH_TYPE=sql_login)
LAKEHOUSE_USER=
LAKEHOUSE_PASSWORD=

# ========== AZURE AD AUTHENTICATION (for device_code flow) ==========
# These are optional - using default Azure CLI client ID if not specified
# FABRIC_TENANT_ID=your-tenant-id
# FABRIC_CLIENT_ID=04b07795-8ddb-461a-bbee-02f9e1bf7b46
# FABRIC_CLIENT_SECRET=

# ========== DATABASE CONFIGURATION ==========
# Local database for caching and user management
DB_TYPE=none
# DB_TYPE=postgresql
# DB_TYPE=mysql
# DB_TYPE=sqlite
# DB_TYPE=mongodb

# PostgreSQL / MySQL
DB_HOST=localhost
DB_PORT=5432
# DB_PORT=3306  # for MySQL
DB_NAME=cashew_forecast
DB_USER=
DB_PASSWORD=
DB_SSL=false
DB_CONNECTION_STRING=

# SQLite
DB_PATH=./data/cashew.db

# ========== LLM PROVIDERS ==========
# Options: openai, anthropic, none
LLM_PROVIDER=none

# API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Rate Limiting
LLM_MAX_CALLS_PER_MIN=5
LLM_MAX_CALLS_PER_DAY=50

# ========== EXTERNAL APIs ==========
# News and Search APIs (optional)
NEWS_API_KEY=
SERP_API_KEY=
BING_API_KEY=

# ========== FRONTEND CONFIGURATION ==========
# Add this to frontend/.env.local
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ============================================
# SETUP INSTRUCTIONS FOR FABRIC LAKEHOUSE
# ============================================
#
# 1. Get your Fabric Lakehouse SQL Endpoint:
#    - Go to your Fabric workspace
#    - Open your Lakehouse
#    - Go to "SQL analytics endpoint"
#    - Copy the connection string (format: xxxxx.datawarehouse.fabric.microsoft.com)
#
# 2. Set LAKEHOUSE_SERVER to the connection string (without port)
#
# 3. Set LAKEHOUSE_DATABASE to your database name
#
# 4. Set LAKEHOUSE_TABLE to your table name (default: dbo.market_prices)
#
# 5. Choose authentication:
#    - device_code: Interactive browser login (easiest)
#    - sql_login: Requires username/password
#
# 6. Test connection:
#    cd backend
#    node debug-fabric.js
#
# ============================================
